{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Runtime Audit Report",
  "type": "object",
  "required": [
    "hardening_policy_version",
    "runtime_image",
    "image_allowlisted",
    "image_present_locally",
    "docker_pull_executed",
    "image_inspect_performed",
    "network_mode",
    "docker_network_none",
    "docker_network_host_forbidden",
    "docker_sock_forbidden",
    "privileged_forbidden",
    "no_new_privileges",
    "cap_drop_all",
    "read_only_rootfs",
    "pids_limit",
    "memory_limit",
    "cpu_limit",
    "timeout_seconds",
    "sample_mount_mode",
    "output_mount_mode",
    "fake_home_used",
    "fake_codex_home_used",
    "real_home_forbidden",
    "real_codex_home_forbidden",
    "real_token_forbidden",
    "real_tokens_passed_to_container",
    "uploaded_script_execution_forbidden",
    "uploaded_scripts_executed",
    "install_command_forbidden",
    "docker_pull_forbidden",
    "codex_executed",
    "strace_executed",
    "local_image_preflight_required",
    "sanitized_env_required",
    "container_started",
    "container_removed",
    "runtime_audit_complete",
    "final_verdict"
  ],
  "properties": {
    "hardening_policy_version": {"type": "string"},
    "runtime_image": {"type": "string"},
    "image_allowlisted": {"type": "boolean"},
    "image_present_locally": {"type": ["boolean", "null"]},
    "docker_pull_executed": {"type": "boolean"},
    "image_inspect_performed": {"type": "boolean"},
    "network_mode": {"const": "none"},
    "docker_network_none": {"type": "boolean"},
    "docker_network_host_forbidden": {"type": "boolean"},
    "docker_sock_forbidden": {"type": "boolean"},
    "privileged_forbidden": {"type": "boolean"},
    "no_new_privileges": {"type": "boolean"},
    "cap_drop_all": {"type": "boolean"},
    "read_only_rootfs": {"type": "boolean"},
    "pids_limit": {"type": ["string", "integer"]},
    "memory_limit": {"type": "string"},
    "cpu_limit": {"type": "string"},
    "timeout_seconds": {"type": "integer"},
    "sample_mount_mode": {"const": "read-only"},
    "output_mount_mode": {"const": "writable"},
    "fake_home_used": {"type": "boolean"},
    "fake_codex_home_used": {"type": "boolean"},
    "real_home_forbidden": {"type": "boolean"},
    "real_codex_home_forbidden": {"type": "boolean"},
    "real_token_forbidden": {"type": "boolean"},
    "real_tokens_passed_to_container": {"type": "boolean"},
    "uploaded_script_execution_forbidden": {"type": "boolean"},
    "uploaded_scripts_executed": {"type": "boolean"},
    "install_command_forbidden": {"type": "boolean"},
    "docker_pull_forbidden": {"type": "boolean"},
    "codex_executed": {"type": "boolean"},
    "strace_executed": {"type": "boolean"},
    "local_image_preflight_required": {"type": "boolean"},
    "sanitized_env_required": {"type": "boolean"},
    "container_started": {"type": "boolean"},
    "container_removed": {"type": "boolean"},
    "runtime_audit_complete": {"type": "boolean"},
    "final_verdict": {"type": "string"}
  },
  "additionalProperties": true
}
