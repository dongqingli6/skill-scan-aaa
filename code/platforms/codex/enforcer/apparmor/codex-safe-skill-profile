#include <tunables/global>

# Prototype AppArmor profile for Codex safe skill sandbox hardening.
# This draft is for plan-only/static validation. Real use requires host
# AppArmor support, apparmor_parser loading, manual security review, and
# small-scale safe_skill-only testing before production enforcement.

profile codex-safe-skill-profile flags=(attach_disconnected,mediate_deleted) {
  # Base process behavior for an unprivileged sandboxed user process.
  file,
  signal,
  unix,

  deny capability sys_admin,
  deny capability sys_ptrace,
  deny capability net_raw,
  deny network raw,

  # Explicitly denied sensitive host material.
  deny /home/*/.ssh/** rwlkmx,
  deny /home/*/.codex/** rwlkmx,
  deny /home/*/.agents/** rwlkmx,
  deny /**/.env rwlkmx,
  deny /var/run/docker.sock rwlkmx,

  # Read-only inputs for Codex safe skill execution.
  /workspace/safe_skill/** r,
  /opt/codex-bundle/** rix,
  /home/codexsafe/** r,

  # Writable scratch and report output.
  /output/** rwk,
  /tmp/** rwk,

  # Minimal runtime paths commonly needed by ordinary user-space tools.
  /bin/** rix,
  /usr/bin/** rix,
  /lib/** r,
  /lib64/** r,
  /usr/lib/** r,
  /etc/ld.so.cache r,
  /etc/ld.so.preload r,
  /etc/passwd r,
  /etc/group r,
  /dev/null rw,
  /dev/zero rw,
  /dev/urandom r,
  /proc/** r,
}
